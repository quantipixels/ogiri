#!/bin/bash
# Pre-push hook: Run build and tests before pushing
# Install via: ./scripts/install.sh

set -e

echo "Running build and tests before push..."

# Run full build with tests
./gradlew build --no-daemon

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Build or tests failed!"
    echo "Fix the issues before pushing."
    echo ""
    exit 1
fi

echo "✓ Build and tests passed"

#!/bin/bash
# Pre-commit hook: Run spotlessCheck before committing
# Install via: ./scripts/install.sh

set -e

echo "Running Spotless check..."

# Run spotlessCheck
./gradlew spotlessCheck --no-daemon -q

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Spotless check failed!"
    echo "Run './gradlew spotlessApply' to fix formatting issues."
    echo ""
    exit 1
fi

echo "✓ Spotless check passed"

#!/bin/bash
# Pre-commit hook: Run spotlessCheck before committing
# Install via: ./scripts/install.sh

set -e

echo "Running Spotless check..."

# Ensure Java 17 is used (required for Kotlin compiler and Spotless compatibility)
if command -v /usr/libexec/java_home &> /dev/null; then
    export JAVA_HOME=$(/usr/libexec/java_home -v 17 2>/dev/null || /usr/libexec/java_home)
fi

# Run spotlessCheck
./gradlew spotlessCheck --no-daemon -q

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Spotless check failed!"
    echo "Run './gradlew spotlessApply' to fix formatting issues."
    echo ""
    exit 1
fi

echo "✓ Spotless check passed"

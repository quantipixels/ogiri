# Git attributes for Ogiri project

# Exclude AI assistant documentation from release archives
sample/**/CLAUDE.md export-ignore
CLAUDE.md export-ignore
AGENTS.md export-ignore

# Exclude development files from release archives
.claude/ export-ignore
.coderabbit.yaml export-ignore
test-samples.sh export-ignore

# Ensure consistent line endings
* text=auto
*.kt text eol=lf
*.java text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.gradle.kts text eol=lf
*.sh text eol=lf

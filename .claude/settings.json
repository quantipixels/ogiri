{
  "project": {
    "name": "ogiri-security",
    "type": "kotlin-spring-security-library",
    "language": "kotlin",
    "framework": "spring-boot",
    "javaVersion": "17"
  },
  "build": {
    "tool": "gradle",
    "wrapper": true,
    "commands": {
      "build": "./gradlew build",
      "test": "./gradlew test",
      "format": "./gradlew spotlessApply",
      "formatCheck": "./gradlew spotlessCheck",
      "coverage": "./gradlew test jacocoTestReport",
      "securityCheck": "./gradlew dependencyCheckAnalyze"
    }
  },
  "conventions": {
    "formatting": {
      "kotlin": "ktfmt",
      "java": "google-java-format"
    },
    "licenseHeader": "spotless.license.kt",
    "testCoverage": {
      "minimum": 50,
      "tool": "jacoco"
    }
  },
  "paths": {
    "source": "ogiri-core/src/main/kotlin",
    "test": "ogiri-core/src/test/kotlin",
    "samples": ["sample/sample-java", "sample/sample-kotlin"],
    "docs": "docs"
  }
}
